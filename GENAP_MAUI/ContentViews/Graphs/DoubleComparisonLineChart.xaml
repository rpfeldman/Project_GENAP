<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
             x:Class="GENAP_MAUI.ContentViews.Graphs.DoubleComparisonLineChart"
             x:Name="Root">

    <VerticalStackLayout Spacing="8">
        <Label x:Name="TitleLabel" Style="{StaticResource ChartTitle}" IsVisible="False" />

        <HorizontalStackLayout Spacing="6" HorizontalOptions="Center"
                               IsVisible="{Binding HasData, Source={x:Reference Root}}">
            <Label Text="{Binding DeltaArrow, Source={x:Reference Root}}"
                   TextColor="{Binding DeltaColor, Source={x:Reference Root}}"
                   FontSize="14"
                   FontAttributes="Bold" />
            <Label Text="{Binding DeltaText, Source={x:Reference Root}}"
                   TextColor="{Binding DeltaColor, Source={x:Reference Root}}"
                   FontSize="14"
                   FontAttributes="Bold" />
        </HorizontalStackLayout>

        <Grid HeightRequest="300">
            <lvc:CartesianChart
                IsVisible="{Binding HasData, Source={x:Reference Root}}"
                Series="{Binding LineSeriesCollection, Source={x:Reference Root}}"
                XAxes="{Binding XAxes, Source={x:Reference Root}}"
                YAxes="{Binding YAxes, Source={x:Reference Root}}"
                LegendPosition="Hidden"
                BackgroundColor="Transparent" />

            <Label IsVisible="{Binding IsEmpty, Source={x:Reference Root}}"
                   Text="Sin movimientos para comparar en este período"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   HorizontalTextAlignment="Center"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
        </Grid>
    </VerticalStackLayout>

</ContentView>