<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
             x:Class="GENAP_MAUI.ContentViews.Graphs.BalanceLineChart"
             x:Name="Root">

    <Border
        Margin="8"
        Padding="16"
        BackgroundColor="#12171F"
        Stroke="#1F2937"
        StrokeThickness="1">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="18"/>
        </Border.StrokeShape>

        <Grid RowDefinitions="Auto,*" RowSpacing="12">

            <VerticalStackLayout Spacing="2">
                <Label Text="Evolución del Balance"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#F8FAFC"/>

                <Label Text="Seguimiento histórico del rendimiento"
                       FontSize="12"
                       TextColor="#94A3B8"/>
            </VerticalStackLayout>

            <Grid Grid.Row="1" HeightRequest="300">
                <lvc:CartesianChart
                    Series="{Binding LineSeriesCollection, Source={x:Reference Root}}"
                    XAxes="{Binding XAxes, Source={x:Reference Root}}"
                    YAxes="{Binding YAxes, Source={x:Reference Root}}"
                    Sections="{Binding ZeroSection, Source={x:Reference Root}}"
                    LegendPosition="Hidden"
                    BackgroundColor="Transparent" />
            </Grid>

        </Grid>
    </Border>
</ContentView>