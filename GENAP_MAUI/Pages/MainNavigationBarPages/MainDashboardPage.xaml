<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GENAP_MAUI.ViewModels"
             xmlns:local="clr-namespace:GENAP_MAUI"
             xmlns:chart="clr-namespace:GENAP_MAUI.ContentViews.Graphs"
             xmlns:model="clr-namespace:DomainModel;assembly=DomainModel"
             x:Class="GENAP_MAUI.Pages.MainNavigationBarPages.MainDashboardPage"
             x:DataType="vm:MainDashboardPageViewModel">

    <ScrollView>
        <VerticalStackLayout>

            <VerticalStackLayout Spacing="15" Padding="15">

                <Label Text="Bienvenido, [usuario]" />

                <Border Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <VerticalStackLayout>
                        <Label Text="Grafico de balance del mes" />
                        <chart:BalanceDoughnutChart Expenses="{Binding MonthExpenses}" Income="{Binding MonthIncome}" />
                    </VerticalStackLayout>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:Routes.Graphs}"/>
                    </Border.GestureRecognizers>
                </Border>


                <Border Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <VerticalStackLayout>
                        <Label Text="Movimientos del mes" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding MonthTransactions}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="model:TransactionDto">
                                    <HorizontalStackLayout Padding="5" Spacing="10">
                                        <Label Text="{Binding Value, StringFormat='{0:N2}$'}" />
                                        <Label Text="{Binding Depletion}" />
                                        <Label Text="{Binding Category}" />
                                        <Label Text="{Binding Date, StringFormat='{0:d}'}" />
                                    </HorizontalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:Routes.TransactionsList}"/>
                    </Border.GestureRecognizers>
                </Border>

            </VerticalStackLayout>


            <VerticalStackLayout>
                <Label Text="Temporal navigation center"></Label>
                <Button Text="Registrar transaccion" Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:Routes.DefaultTransaction}"></Button>
                <Button Text="Registrar transaccion de trading" Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:Routes.TradingTransactions}" ></Button>
                <Button Text="Ir a la lista de categorias" Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:Routes.Categories}" ></Button>
                <Button Text="Ir a la seccion de graficos" Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:Routes.Graphs}" ></Button>
                <Button Text="Ir a la lista de movimientos" Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:Routes.TransactionsList}"></Button>
            </VerticalStackLayout>
           
        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>