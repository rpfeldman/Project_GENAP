<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GENAP_MAUI.ViewModels"
             xmlns:charts="clr-namespace:GENAP_MAUI.ContentViews.Graphs"
             x:Class="GENAP_MAUI.Pages.MainNavigationBarPages.GraphsPage"
             x:DataType="vm:GraphsPageViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}">

    <Grid RowDefinitions="Auto,*">

        <Border Grid.Row="0"
                Style="{StaticResource InputField}"
                Margin="20,16,20,8">
            <Picker Title="Seleccionar período de tiempo"
                    ItemsSource="{Binding GlobalResources.TimePeriodsList}"
                    ItemDisplayBinding="{Binding Value}"
                    SelectedItem="{Binding PickedTimePeriod}" />
        </Border>

        <ScrollView Grid.Row="1" Padding="20,8,20,20">
            <VerticalStackLayout Spacing="0">

                <Label Text="Balance general" Style="{StaticResource SectionHeader}" />

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <Label Text="Ingresos vs. gastos" Style="{StaticResource ChartTitle}" />
                        <charts:BalanceDoughnutChart Expenses="{Binding Expenses}" Income="{Binding Income}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <Label Text="Evolución del balance" Style="{StaticResource ChartTitle}" />
                        <charts:BalanceLineChart Transactions="{Binding TransactionsLog}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <Label Text="Proporción global" Style="{StaticResource ChartTitle}" />
                        <charts:ProportionDoughnutChart Categories="{Binding Categories}" Transactions="{Binding TransactionsLog}" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="Análisis de gastos" Style="{StaticResource SectionHeader}" />

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <Label Text="Proporción de gastos" Style="{StaticResource ChartTitle}" />
                        <charts:ProportionDoughnutChart Categories="{Binding Categories}" Transactions="{Binding ExpensesLog}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <Label Text="Evolución de gastos" Style="{StaticResource ChartTitle}" />
                        <charts:BasicLineChart Transactions="{Binding ExpensesLog}" LineColor="{StaticResource ExpenseRed}" />
                    </VerticalStackLayout>
                </Border>
                
                <Label Text="Análisis de ingresos" Style="{StaticResource SectionHeader}" />

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <Label Text="Proporción de ingresos" Style="{StaticResource ChartTitle}" />
                        <charts:ProportionDoughnutChart Categories="{Binding Categories}" Transactions="{Binding IncomeLog}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <Label Text="Evolución de ingresos" Style="{StaticResource ChartTitle}" />
                        <charts:BasicLineChart Transactions="{Binding IncomeLog}" LineColor="{StaticResource IncomeGreen}" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="Comparativas" Style="{StaticResource SectionHeader}" />

                <Border Style="{StaticResource ChartCard}">
                    <VerticalStackLayout>
                        <Label Text="Ingresos vs. gastos en el tiempo" Style="{StaticResource ChartTitle}" />
                        <charts:DoubleComparisonLineChart Transactions1="{Binding IncomeLog}" Color1="{StaticResource IncomeGreen}"
                                                          Transactions2="{Binding ExpensesLog}" Color2="{StaticResource ExpenseRed}" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
    
</ContentPage>