<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GENAP_MAUI.ViewModels"
             xmlns:model="clr-namespace:DomainModel;assembly=DomainModel"
             x:Class="GENAP_MAUI.Pages.TransactionRelatedPages.TransactionsCollectionPage"
             x:DataType="vm:TransactionsCollectionPageViewModel">


    <Grid RowDefinitions="Auto, *, Auto">

        <Picker
            Grid.Row="0"
		    Title="Seleccionar periodo de tiempo"
		    ItemsSource="{Binding GlobalResources.TimePeriodsList}"
		    ItemDisplayBinding="{Binding Value}"
		    SelectedItem="{Binding PickedTimePeriod}"/>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Transactions}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:TransactionDto">

                    <HorizontalStackLayout Padding="5" Spacing="10">
                        <Label Text="{Binding Value, StringFormat='{0:N2}$'}"></Label>
                        <Label Text="{Binding Depletion}"></Label>
                        <Label Text="{Binding Category}"></Label>
                        <Label Text="{Binding Date, StringFormat='{0:d}'}"></Label>
                        <Button Text="Editar" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TransactionsCollectionPageViewModel}}, Path=NavigateIntoTransactionCommand}" CommandParameter="{Binding TransactionId}"></Button>
                    </HorizontalStackLayout>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Button Grid.Row="2" Text="Reiniciar datos" Command="{Binding RestartDataCommand}" />

    </Grid>
</ContentPage>