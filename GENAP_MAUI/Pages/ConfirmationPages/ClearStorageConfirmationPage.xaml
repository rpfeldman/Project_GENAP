<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GENAP_MAUI.ViewModels"
             xmlns:local="clr-namespace:GENAP_MAUI"
             x:Class="GENAP_MAUI.Pages.ConfirmationPages.ClearStorageConfirmationPage"
             x:DataType="vm:ClearStorageConfirmationPageViewModel">

    <ScrollView>
        <VerticalStackLayout Style="{StaticResource FormContainer}"
                             Padding="20,32,20,32"
                             Spacing="24">

            <Label Text="{x:Static local:Symbols.WarningIcon}"
                   Style="{StaticResource WarningIconLabel}"
                   Margin="0,24,0,0" />

            <Label Text="ADVERTENCIA"
                   Style="{StaticResource WarningHeadline}" />
            
            <Border Style="{StaticResource DangerCard}">
                <VerticalStackLayout Spacing="12" Padding="0">

                    <Label Text="Usted está a un paso de borrar y reiniciar todos los movimientos guardados de la aplicación."
                           Style="{StaticResource FieldLabel}"
                           HorizontalTextAlignment="Center" />

                    <Label Text="Esta acción es irreversible."
                           TextColor="{StaticResource DangerRed}"
                           FontAttributes="Bold"
                           FontSize="15"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />

                    <Label Text="Si no está seguro de lo que está haciendo, le recomendamos volver atrás."
                           Style="{StaticResource Caption}"
                           HorizontalTextAlignment="Center" />

                </VerticalStackLayout>
            </Border>

            <Label Text="¿Desea continuar con el reinicio de datos o volver al menú?"
                   Style="{StaticResource Caption}"
                   HorizontalTextAlignment="Center"
                   Margin="0,8,0,0" />

            <VerticalStackLayout Spacing="12" Padding="0">

                <Button Text="No, volver al menú"
                        Style="{StaticResource ButtonPrimary}"
                        Command="{Binding DirectNavigateCommand}"
                        CommandParameter="{x:Static local:Routes.Dashboard}" />

                <Button Text="Sí, reiniciar los datos"
                        Style="{StaticResource ButtonDangerOutline}"
                        Command="{Binding ClearStorageCommand}" />

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>